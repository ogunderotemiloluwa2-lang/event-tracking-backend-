# Backend environment variables.
# Copy to ".env" locally, or set each of these in the Render dashboard
# (Environment > Environment Variables). NEVER commit the real .env.

# --- MongoDB ---
# Use your Atlas SRV string in production (Render's DNS resolves SRV fine):
MONGODB_URI=mongodb+srv://username:password@your-cluster.mongodb.net/event_tracking?retryWrites=true&w=majority

# --- Server ---
# Render sets PORT automatically; the app reads process.env.PORT.
PORT=5000
NODE_ENV=production

# --- JWT Authentication ---
JWT_SECRET=change_this_to_a_long_random_secret

# --- Google Drive Service Account (photo storage) ---
# Paste the full service-account JSON as a single line.
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key":"..."}

# --- Google OAuth (optional, only if using per-organizer Drive connect) ---
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=https://your-frontend-domain/auth/callback

# --- Cloudinary (backup photo storage, optional) ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- Email Service (Gmail app password, not your normal password) ---
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_16_char_app_password

# --- App URLs ---
# Set APP_URL to your deployed frontend (Netlify) URL once known.
APP_URL=https://your-frontend.netlify.app
